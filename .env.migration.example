# Copy this file to .env.migration and fill in real local values.
# Do not commit .env.migration.

# Live MongoDB source. Keep this secret.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?replicaSet=REPLICA_SET&tls=true&authSource=admin
MONGO_DB=hyejoo2

# Local PostgreSQL target.
PG_HOST=localhost
PG_PORT=5432
PG_USER=root
PG_PASSWORD=root
PG_DATABASE=postgres
PG_SSLMODE=disable

# Migration tuning.
MIGRATION_BATCH_SIZE=1000
MIGRATION_INSERT_MODE=batch
MIGRATION_USE_COPY=false
MIGRATION_SLEEP_MS=0

# Safety defaults.
MIGRATION_RESET_BEFORE=false
MIGRATION_RESET_ON_ERROR=false
MIGRATION_AUTO_CREATE_MISSING_CARDS=false
